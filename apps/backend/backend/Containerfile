# =============================================================
#  JuggleFlow — Backend Containerfile
#  Multi-stage build : Maven build + lightweight JRE runtime
#  Compatible Podman (rootless)
# =============================================================

# ── Stage 1 : Build ──────────────────────────────────────────
FROM maven:3.9.9-eclipse-temurin-21-alpine AS builder

WORKDIR /build

# Copy dependency descriptors first (layer cache optimisation)
COPY pom.xml .
RUN mvn dependency:go-offline -q

# Copy source and build
COPY src ./src
RUN mvn clean package -DskipTests -q

# ── Stage 2 : Runtime ────────────────────────────────────────
FROM eclipse-temurin:21-jre-alpine AS runtime

# Security: run as non-root user
RUN addgroup -S juggleflow && adduser -S juggleflow -G juggleflow

WORKDIR /app

# Copy compiled jar from builder stage
COPY --from=builder /build/target/*.jar app.jar

# Set ownership
RUN chown juggleflow:juggleflow app.jar

USER juggleflow

# Expose application port
EXPOSE 8080

# JVM tuning for containers
ENV JAVA_OPTS="-XX:+UseContainerSupport \
               -XX:MaxRAMPercentage=75.0 \
               -XX:+UseG1GC \
               -Djava.security.egd=file:/dev/./urandom"

ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar app.jar"]
