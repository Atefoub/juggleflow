## JuggleFlow Backend — Exemple de configuration locale
## Copie en `.env` puis adapte les valeurs (NE PAS COMMIT).

# PostgreSQL
POSTGRES_DB=juggleflow_db
POSTGRES_USER=juggleflow_user
POSTGRES_PASSWORD=change-me

# JWT
# Doit faire >= 32 caractères (ou mieux: une valeur base64 longue).
JWT_SECRET=change-me-please-generate-a-long-secret
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# HTTP
SERVER_PORT=8080

# CORS
# Exemple dev: http://localhost:4200
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Swagger (dev uniquement)
SWAGGER_ENABLED=false
SWAGGER_PUBLIC=false

# Cookies
# Dev HTTP (localhost): false ; Prod HTTPS: true
COOKIE_SECURE=false

# Reverse proxy (prod uniquement derrière un proxy de confiance)
APP_TRUSTED_PROXY=false

# Rate limiting (tests / debug)
APP_RATE_LIMIT_ENABLED=true

# Admin bootstrap (DEV UNIQUEMENT — NE PAS définir en prod)
# Si les deux variables sont renseignées, un compte ROLE_ADMINISTRATEUR est créé
# au démarrage (idempotent). Mot de passe : >= 8 chars, 1 minuscule, 1 majuscule, 1 chiffre.
# Voir com.juggleflow.backend.bootstrap.AdminBootstrapRunner pour la logique complète.
#ADMIN_BOOTSTRAP_EMAIL=admin@juggleflow.local
#ADMIN_BOOTSTRAP_PASSWORD=Admin2026!

# Demo bootstrap (DEV UNIQUEMENT — enseignants, classes, élèves de test)
# Après reset DB : active, redémarre le backend une fois.
#DEMO_BOOTSTRAP_ENABLED=true
#DEMO_BOOTSTRAP_PASSWORD=Demo2026!
#
# Comptes créés (même mot de passe DEMO_BOOTSTRAP_PASSWORD pour tous) :
#   Admin (si ADMIN_BOOTSTRAP_* défini) : admin@juggleflow.local
#   Enseignants : marie.dupont@ecole.fr | pierre.lefebvre@ecole.fr | sophie.renard@ecole.fr
#   Élèves CE1  : lucas.martin@ecole.fr (bloqué Shower), emma.rousseau@ecole.fr, …
