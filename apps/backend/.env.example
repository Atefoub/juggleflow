# ================================================================
#  JuggleFlow — Variables d'environnement (TEMPLATE)
#  Copiez ce fichier en .env et remplissez les valeurs réelles.
#  Le fichier .env NE DOIT PAS être commité (voir .gitignore).
# ================================================================

# Base de données PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/juggleflow_db
DB_USERNAME=juggleflow_user
DB_PASSWORD=CHANGEME_mot_de_passe_fort

# JWT — générez une clé aléatoire de 256 bits minimum
# Exemple : openssl rand -base64 64
JWT_SECRET=CHANGEME_cle_secrete_tres_longue_minimum_256_bits
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Serveur
SERVER_PORT=8080

# CORS — origines autorisées (frontend)
CORS_ALLOWED_ORIGINS=http://localhost:5173
