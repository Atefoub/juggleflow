{
  "name": "backend",
  "projectType": "application",
  "root": "apps/backend",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node nx-mvn.mjs clean package -DskipTests",
        "cwd": "apps/backend"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node nx-mvn.mjs test",
        "cwd": "apps/backend"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "node nx-mvn.mjs spring-boot:run",
        "cwd": "apps/backend"
      }
    }
  }
}